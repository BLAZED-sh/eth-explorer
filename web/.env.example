# Build-time backend location for the frontend.
# These are read by Vite and baked into the bundle at `npm run build`, so they
# must be set before building. Leave empty to serve the frontend from the same
# origin as the backend (the default, embedded-binary setup).

# Absolute origin of the REST API, e.g. https://explorer-api.example.com
VITE_API_BASE=

# Full WebSocket URL. If empty, it is derived from VITE_API_BASE (or, when that
# is also empty, from the page origin). e.g. wss://explorer-api.example.com/ws
VITE_WS_URL=
