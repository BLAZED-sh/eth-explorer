# Ethereum node RPC endpoints (needs eth + txpool API namespaces)
ETH_HTTP_URL=http://127.0.0.1:8545
ETH_WS_URL=ws://127.0.0.1:8546

# Server
LISTEN_ADDR=:8080
DB_PATH=./explorer.db

# CORS: comma-separated origins allowed to call the API / open the WebSocket.
# Only needed when the frontend is served from a different origin than this
# backend (a VITE_API_BASE build). Empty = same-origin only; "*" = any origin.
# e.g. ALLOW_ORIGINS=https://explorer.example.com
ALLOW_ORIGINS=

# Data retention
RETENTION_HOURS=48
MAX_POOL=10000

# TLS / HTTPS
# Option A: bring your own cert (takes precedence over ACME).
#TLS_CERT_FILE=/path/to/fullchain.pem
#TLS_KEY_FILE=/path/to/privkey.pem
# Option B: obtain a Let's Encrypt cert in-process via a manual dns-01 flow.
# On first run the server logs a TXT record to create, waits ACME_DNS_WAIT
# seconds for you to add it, then issues and caches the cert in CERT_CACHE.
ACME_ENABLED=false
DOMAIN=
ACME_EMAIL=
CERT_CACHE=./certs
ACME_DNS_WAIT=600
# Set to the LE staging directory for testing (avoids rate limits):
# ACME_DIRECTORY=https://acme-staging-v02.api.letsencrypt.org/directory
ACME_DIRECTORY=
